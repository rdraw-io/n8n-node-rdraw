{
    "name": "n8n-nodes-rdraw",
    "version": "0.1.6",
    "description": "Nó para integração com a API de geração de documentos rdraw.io",
    "license": "MIT",
    "homepage": "https://rdraw.io",
    "keywords": [
        "n8n-community-node-package",
        "reporting",
        "pdf-generation",
        "rdraw"
    ],
    "author": {
        "name": "RDraw",
        "email": "hello@rdraw.io"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rdraw-io/n8n-node-rdraw.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/RDrawApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/RDraw/RDraw.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.39.4",
        "prettier": "3.8.3",
        "release-it": "20.0.1",
        "typescript": "5.9.3"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
